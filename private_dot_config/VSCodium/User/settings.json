{
    "workbench.colorTheme": "Berg Theme",
    "extensions.experimental.affinity": {
        "asvetliakov.vscode-neovim": 1
    },
    "editor.fontFamily": "'BloombergFixedUnicodeN Nerd Font Mono', monospace",
    "editor.fontLigatures": true,
    "terminal.integrated.defaultProfile.linux": "zsh",
    "terminal.integrated.profiles.linux": {
        "fish": {
            "path": "/usr/bin/fish"
        }
    },
    "workbench.secondarySideBar.defaultVisibility": "hidden",
    "git.openRepositoryInParentFolders": "never",
    "git.autofetch": true,
    "lean4.alwaysAskBeforeInstallingLeanVersions": false,
    "zig.zls.enabled": "on",
    "editor.fontSize": 16,
    "workbench.bottomPane.experimental.fontSize": 16,
    "workbench.sideBar.experimental.fontSize": 16,
    "workbench.tabs.experimental.fontSize": 16,
    "terminal.integrated.fontSize": 16,
    "lldb.suppressUpdateNotifications": true
}