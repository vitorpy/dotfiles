# Mako notification daemon configuration - Berg theme

# Positioning
anchor=top-right
margin=20
padding=15

# Appearance
width=350
height=150
border-size=2
border-radius=10

# Colors (Berg)
background-color=#282828
text-color=#acacae
border-color=#464646

# Progress bar
progress-color=over #f49f31

# Font
font=Avenir Next M for BBG 11

# Timeout (milliseconds)
default-timeout=5000
ignore-timeout=0

# Icons
icons=1
max-icon-size=48
icon-path=/usr/share/icons/Yaru

# Grouping
group-by=app-name

# Do Not Disturb mode
[mode=do-not-disturb]
invisible=1

# Urgency overrides
[urgency=low]
border-color=#202020

[urgency=critical]
border-color=#f49f31
text-color=#d7d7d7
