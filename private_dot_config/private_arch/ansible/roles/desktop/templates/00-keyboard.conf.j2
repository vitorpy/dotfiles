Section "InputClass"
        Identifier "system-keyboard"
        MatchIsKeyboard "on"
        Option "XkbLayout" "{{ arch_x11_keymap_layouts }}"
        Option "XkbModel" "{{ arch_x11_keymap_model }}"
        Option "XkbVariant" "{{ arch_x11_keymap_variant }}"
        Option "XkbOptions" "{{ arch_x11_keymap_options }}"
EndSection
