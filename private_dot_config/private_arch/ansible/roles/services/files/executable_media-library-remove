def remove_path(path: Path) -> None:
    if not path.exists():
        return
    if path.is_dir() and not path.is_symlink():
        shutil.rmtree(path)
    else:
        path.unlink()


def prune_empty_parents(paths: list[Path], roots: list[Path]) -> None:
    root_resolved = {root.resolve(strict=False) for root in roots}
    for path in paths:
        current = path.parent
        while current.resolve(strict=False) not in root_resolved and any(is_under(current, root) for root in roots):
            try:
                current.rmdir()
            except OSError:
                break
            current = current.parent


def item_paths_exist(item: JellyfinItem) -> bool:
    return any(path.exists() for path in item.paths)


def delete_jellyfin_item(item: JellyfinItem, args: argparse.Namespace) -> tuple[int, str]:
    if args.jellyfin_items_json:
        data = load_fixture(args.jellyfin_items_json) or []
        rows = data.get("Items", data) if isinstance(data, dict) else data
        raw_item = next((row for row in rows if str(row.get("Id") or "") == item.id), None)
        if raw_item is None:
            return 404, "fixture item not found"
        raw_paths = item_paths(raw_item)
        if raw_item.get("FailWhenMissing") and not any(path.exists() for path in raw_paths):
            return 500, "missing backing file"
        rows = [row for row in rows if str(row.get("Id") or "") != item.id]
        save_fixture(args.jellyfin_items_json, {"Items": rows} if isinstance(data, dict) else rows)
        append_log(args.jellyfin_delete_log, f"jellyfin {item.id}")
        return 204, ""
    api_key = jellyfin_api_key(args)
    if not api_key:
        return 0, "Jellyfin API key unavailable"
    return http_status(f"{args.jellyfin_url.rstrip('/')}/Items/{item.id}", method="DELETE", api_key=api_key, timeout=args.timeout)


def delete_jellyfin_items(plan: Plan, args: argparse.Namespace) -> None:
    if not plan.jellyfin_delete:
        return
    for item in plan.jellyfin_items:
        status, body = delete_jellyfin_item(item, args)
        if 200 <= status < 300:
            print(f"deleted jellyfin item id={item.id} name={item.name!r}")
            continue
        if item_paths_exist(item):
            raise RuntimeError(f"jellyfin delete failed id={item.id} name={item.name!r} status={status}: {body[:200]}")
        plan.warnings.append(f"jellyfin: stale item delete deferred id={item.id} status={status}")


def create_placeholder_paths(item: JellyfinItem, roots: list[Path]) -> tuple[list[Path], list[Path]]:
    created_files: list[Path] = []
    created_dirs: list[Path] = []
    for path in item.paths:
        if not path_allowed(path, roots):
            continue
        missing_dirs: list[Path] = []
        current = path.parent
        while not current.exists() and path_allowed(current, roots):
            missing_dirs.append(current)
            current = current.parent
        path.parent.mkdir(parents=True, exist_ok=True)
        for directory in reversed(missing_dirs):
            created_dirs.append(directory)
            os.chmod(directory, 0o777)
        if not path.exists():
            path.touch()
            os.chmod(path, 0o666)
            created_files.append(path)
    return created_files, created_dirs


def cleanup_placeholders(files: list[Path], directories: list[Path]) -> None:
    for path in files:
        try:
            if path.exists() and path.stat().st_size == 0:
                path.unlink()
        except OSError:
            pass
    for directory in sorted(directories, key=lambda value: len(value.parts), reverse=True):
        try:
            directory.rmdir()
        except OSError:
            pass


def cleanup_stale_jellyfin_items(targets: list[Path], args: argparse.Namespace, roots: list[Path]) -> None:
    if args.no_jellyfin or args.no_jellyfin_delete:
        return
    warnings: list[str] = []
    stale_items = jellyfin_items_under_paths(jellyfin_items(args, warnings), targets)
    for warning in warnings:
        print(f"WARNING: {warning}", file=sys.stderr)
    for item in stale_items:
        status, body = delete_jellyfin_item(item, args)
        if 200 <= status < 300:
            print(f"deleted stale jellyfin item id={item.id} name={item.name!r}")
            continue
        if item_paths_exist(item):
            continue
        created_files, created_dirs = create_placeholder_paths(item, roots)
        try:
            status, body = delete_jellyfin_item(item, args)
            if 200 <= status < 300:
                print(f"deleted stale jellyfin item with placeholder id={item.id} name={item.name!r}")
            else:
                print(f"WARNING: jellyfin stale delete failed id={item.id} status={status}: {body[:200]}", file=sys.stderr)
        finally:
            cleanup_placeholders(created_files, created_dirs)


def refresh_jellyfin(args: argparse.Namespace) -> None:
    if args.jellyfin_items_json:
        append_log(args.jellyfin_delete_log, "jellyfin refresh")
        return
    api_key = jellyfin_api_key(args)
    if not api_key or args.no_jellyfin:
        return
    http_json(f"{args.jellyfin_url.rstrip('/')}/Library/Refresh", method="POST", api_key=api_key, data=b"", timeout=args.timeout)


def verification_report(plan: Plan, args: argparse.Namespace) -> dict[str, Any]:
    roots = managed_roots(args)
    targets = sorted(plan.delete_paths)
    report: dict[str, Any] = {
        "paths": [str(path) for path in targets if path.exists()],
        "sonarr": [],
        "radarr": [],
        "transmission": [],
        "jellyfin": [],
        "warnings": [],
    }

    def arr_residuals(app: str, planned: list[AppItem]) -> list[dict[str, Any]]:
        if (app == "sonarr" and args.no_sonarr) or (app == "radarr" and args.no_radarr):
            return []
        base_url = args.sonarr_url if app == "sonarr" else args.radarr_url
        config = Path(args.sonarr_config if app == "sonarr" else args.radarr_config)
        fixture_path = args.sonarr_series_json if app == "sonarr" else args.radarr_movies_json
        warnings: list[str] = []
        items = arr_items(app, base_url, config, args.timeout, warnings, fixture_path)
        report["warnings"].extend(warnings)
        planned_ids = {item.id for item in planned}
        residuals = []
        for item in items:
            if item.id in planned_ids or (item.path and any(selected_container_matches_path(target, item.path) for target in targets)):
                residuals.append({"id": item.id, "title": item.title, "path": str(item.path) if item.path else None})
        return residuals

    report["sonarr"] = arr_residuals("sonarr", plan.sonarr)
    report["radarr"] = arr_residuals("radarr", plan.radarr)

    if not args.no_transmission:
        try:
            torrents = TransmissionRpc(args.transmission_url, args.timeout).torrents()
            planned_ids = {torrent.id for torrent in plan.torrents}
            for torrent in torrents:
                common_path = common_torrent_path(torrent)
                if torrent.id in planned_ids or (common_path and any(selected_container_matches_path(target, common_path) for target in targets)):
                    report["transmission"].append({"id": torrent.id, "name": torrent.name, "hash_string": torrent.hash_string})
        except Exception as exc:
            report["warnings"].append(f"transmission: could not verify torrents: {exc}")

    if not args.no_jellyfin and jellyfin_api_key(args):
        warnings: list[str] = []
        for item in jellyfin_items_under_paths(jellyfin_items(args, warnings), targets):
            report["jellyfin"].append(
                {
                    "id": item.id,
                    "name": item.name,
                    "type": item.type,
                    "paths": [str(path) for path in item.paths],
                }
            )
        report["warnings"].extend(warnings)

    return report


def verification_failed(report: dict[str, Any]) -> bool:
    return any(report[key] for key in ("paths", "sonarr", "radarr", "transmission", "jellyfin"))


def print_verification(report: dict[str, Any]) -> None:
    print("verification:")
    for key in ("paths", "sonarr", "radarr", "transmission", "jellyfin"):
        print(f"  {key}: {len(report[key])}")
    for warning in report["warnings"]:
        print(f"WARNING: {warning}", file=sys.stderr)


def apply_plan(plan: Plan, args: argparse.Namespace) -> None:
    roots = managed_roots(args)
    assert_preflight_ok(plan)
    delete_jellyfin_items(plan, args)
    for torrent in plan.torrents:
        TransmissionRpc(args.transmission_url, args.timeout).remove(torrent.id)
        print(f"removed transmission torrent id={torrent.id} name={torrent.name!r}")
    for item in plan.sonarr:
        delete_arr_item(item, args)
        print(f"removed sonarr series id={item.id} title={item.title!r}")
    for item in plan.radarr:
        delete_arr_item(item, args)
        print(f"removed radarr movie id={item.id} title={item.title!r}")
    deleted_paths = sorted(plan.delete_paths, key=lambda path: len(path.parts), reverse=True)
    for path in deleted_paths:
        if not path_allowed(path, roots):
            raise RuntimeError(f"refusing unmanaged or root path during apply: {path}")
        if path.exists():
            remove_path(path)
            print(f"deleted path={path}")
    prune_empty_parents(deleted_paths, roots)
    refresh_jellyfin(args)
    if plan.jellyfin_refresh:
        print("requested Jellyfin library refresh")
    if not args.no_verify:
        cleanup_stale_jellyfin_items(deleted_paths, args, roots)
        report = verification_report(plan, args)
        print_verification(report)
        if verification_failed(report):
            raise RuntimeError("post-delete verification failed; residual media references remain")


def build_arg_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(
        description="Remove one media entry from Arr apps, Transmission, Jellyfin-visible libraries, and download hardlinks.",
    )
    parser.add_argument("query", nargs="?", help="Title/path/id substring to search. Refine ambiguous matches with explicit selectors.")
    parser.add_argument("--path", action="append", help="Absolute media path to remove. Can be repeated.")
    parser.add_argument("--sonarr-id", type=int, action="append", help="Sonarr series id to remove. Can be repeated.")
    parser.add_argument("--radarr-id", type=int, action="append", help="Radarr movie id to remove. Can be repeated.")
    parser.add_argument("--transmission-id", type=int, action="append", help="Transmission torrent id to remove. Can be repeated.")
    parser.add_argument("--allow-multiple", action="store_true", help="Allow a query to select multiple distinct entries.")
    parser.add_argument("--apply", action="store_true", help="Actually delete records/files. Default is dry-run.")
    parser.add_argument("--arr-delete-files", action="store_true", help="Ask Sonarr/Radarr to delete files too. Default leaves file deletion to this tool.")
    parser.add_argument("--json", action="store_true", help="Print the removal plan as JSON.")
    parser.add_argument("--download-root", default=str(DEFAULT_DOWNLOAD_ROOT))
    parser.add_argument("--series-root", default=str(DEFAULT_SERIES_ROOT))
    parser.add_argument("--films-root", default=str(DEFAULT_FILMS_ROOT))
    parser.add_argument("--music-root", default=str(DEFAULT_MUSIC_ROOT))
    parser.add_argument("--queue-root", default=str(DEFAULT_QUEUE_ROOT))
    parser.add_argument("--sonarr-url", default=DEFAULT_SONARR_URL)
    parser.add_argument("--radarr-url", default=DEFAULT_RADARR_URL)
    parser.add_argument("--transmission-url", default=DEFAULT_TRANSMISSION_URL)
    parser.add_argument("--jellyfin-url", default=DEFAULT_JELLYFIN_URL)
    parser.add_argument("--sonarr-config", default=str(DEFAULT_SONARR_CONFIG))
    parser.add_argument("--radarr-config", default=str(DEFAULT_RADARR_CONFIG))
    parser.add_argument("--jellyfin-env", default=str(DEFAULT_JELLYFIN_ENV))
    parser.add_argument("--jellyfin-api-key", default=None)
    parser.add_argument("--timeout", type=int, default=20)
    parser.add_argument("--no-sonarr", action="store_true")
    parser.add_argument("--no-radarr", action="store_true")
    parser.add_argument("--no-transmission", action="store_true")
    parser.add_argument("--no-jellyfin", action="store_true")
    parser.add_argument("--no-jellyfin-delete", action="store_true", help="Only refresh Jellyfin; do not delete matched Jellyfin items first.")
    parser.add_argument("--no-hardlink-scan", action="store_true")
    parser.add_argument("--no-verify", action="store_true", help="Skip post-apply verification.")
    parser.add_argument("--jellyfin-items-json", help=argparse.SUPPRESS)
    parser.add_argument("--jellyfin-delete-log", help=argparse.SUPPRESS)
    parser.add_argument("--sonarr-series-json", help=argparse.SUPPRESS)
    parser.add_argument("--sonarr-delete-log", help=argparse.SUPPRESS)
    parser.add_argument("--radarr-movies-json", help=argparse.SUPPRESS)
    parser.add_argument("--radarr-delete-log", help=argparse.SUPPRESS)
    return parser


def main() -> int:
    args = build_arg_parser().parse_args()
    plan = build_plan(args)
    record = plan_record(plan, args)
    if args.json:
        print(json.dumps(record, indent=2, sort_keys=True))
    else:
        print_human(record)
    if args.apply:
        apply_plan(plan, args)
    return 0


if __name__ == "__main__":
    try:
        raise SystemExit(main())
    except Exception as exc:
        print(f"ERROR: {exc}", file=sys.stderr)
        raise SystemExit(1)
