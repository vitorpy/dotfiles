#!/usr/bin/env python3
"""Transmission media sorter hook and queue processor."""

from __future__ import annotations

import sys
from pathlib import Path


LOCAL_LIB = Path(__file__).resolve().parent / "media-sorter"
if LOCAL_LIB.exists():
    sys.path.insert(0, str(LOCAL_LIB))
else:
    sys.path.insert(0, "/usr/local/lib/media-sorter")

from media_sorter.cli import main


if __name__ == "__main__":
    raise SystemExit(main())
