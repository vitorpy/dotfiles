    (re.compile(r"(?i)^kino[ ._-]*\d{1,3}(?:\b|[ ._-])"), "shorts"),
    (re.compile(r"(?i)(?:^|[ ._-])interviews?[ ._-]*\d{1,3}(?:\b|[ ._-])"), "interviews"),
    (re.compile(r"(?i)(?:^|[ ._-])interviews?(?:\b|[ ._-])"), "interviews"),
